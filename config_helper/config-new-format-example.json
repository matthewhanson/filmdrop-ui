{
  "_comment": "This is an example config using the NEW consolidated COLLECTIONS_CONFIG structure.",
  "_comment2": "This format consolidates all per-collection parameters into a single object for easier maintenance.",

  "PUBLIC_URL": "http://example.com/",
  "LOGO_URL": "/logo.png",
  "LOGO_ALT": "Alt description for my custom logo",
  "COLLECTIONS": {
    "default": "sentinel-2-l2a",
    "include": ["sentinel-2-l2a", "landsat-c2-l2", "naip"]
  },
  "STAC_API_URL": "https://api-endpoint.example.com",
  "STAC_LINK_ENABLED": true,
  "SHOW_ITEM_AUTO_ZOOM": true,
  "API_MAX_ITEMS": 200,
  "SCENE_TILER_URL": "https://titiler.example.com",
  "MOSAIC_TILER_URL": "https://titiler-mosaic.example.com",
  "MOSAIC_MAX_ITEMS": 100,
  "CONFIG_COLORMAP": "viridis",
  "BASEMAP": {
    "url": "https://tile-provider.example.com/{z}/{x}/{y}.png",
    "attribution": "&copy; <a href=\"https://www.tile-provider.example.com/copyright\">TileProvider</a>"
  },
  "THEME_SWITCHING_ENABLED": true,
  "SEARCH_BY_GEOM_ENABLED": false,
  "CART_ENABLED": false,
  "EXCLUDED_QUERYABLES": ["datetime", "geometry", "sci:doi", "proj:*"],
  "_comment_EXCLUDED_QUERYABLES": "Queryable fields to exclude from filters. Supports exact matches and prefix patterns (use '*' suffix for prefix, e.g., 'proj:*' excludes all proj: fields)",

  "_comment_COLLECTIONS_CONFIG": "NEW: COLLECTIONS_CONFIG consolidates all collection-specific parameters",
  "COLLECTIONS_CONFIG": {
    "sentinel-2-l2a": {
      "sceneTilerParams": {
        "assets": ["red", "green", "blue"],
        "color_formula": "Gamma+RGB+3.2+Saturation+0.8+Sigmoidal+RGB+12+0.35"
      },
      "mosaicTilerParams": {
        "assets": ["visual"]
      },
      "sceneMinZoom": 7,
      "popupDisplayFields": ["datetime", "platform", "eo:cloud_cover"],
      "tileLayerParams": {
        "minZoom": 2,
        "minNativeZoom": 2,
        "maxZoom": 26,
        "maxNativeZoom": 18
      },
      "enhancedDisplayConfig": {
        "property_groups": [
          {
            "name": "Core Fields",
            "fields": [
              { "name": "datetime", "label": "Acquisition Time" },
              { "name": "platform" },
              { "name": "constellation" }
            ]
          },
          {
            "name": "Data Quality",
            "fields": [{ "name": "eo:cloud_cover" }]
          }
        ],
        "asset_groups": [
          {
            "name": "10m Bands",
            "fields": [
              { "name": "red" },
              { "name": "green" },
              { "name": "blue" },
              { "name": "nir" }
            ]
          }
        ]
      }
    },
    "landsat-c2-l2": {
      "sceneTilerParams": {
        "assets": ["red", "green", "blue"],
        "color_formula": "Gamma+RGB+1.7+Saturation+1.7+Sigmoidal+RGB+15+0.35"
      },
      "mosaicTilerParams": {
        "assets": ["red"],
        "color_formula": "Gamma+R+1.7+Sigmoidal+R+15+0.35"
      },
      "sceneMinZoom": 7,
      "popupDisplayFields": [
        "datetime",
        "platform",
        "instruments",
        "eo:cloud_cover"
      ],
      "tileLayerParams": {
        "minZoom": 2,
        "maxZoom": 26
      }
    },
    "naip": {
      "sceneTilerParams": {
        "assets": ["image"],
        "bidx": "1,2,3"
      },
      "mosaicTilerParams": {
        "assets": ["image"],
        "bidx": "1,2,3"
      },
      "sceneMinZoom": 14,
      "popupDisplayFields": ["datetime", "naip:state", "naip:year", "gsd"]
    }
  },

  "_comment_OLD_FORMAT": "==== DEPRECATED OLD FORMAT (still supported for backwards compatibility) ====",
  "_comment_OLD_FORMAT2": "The following parameters are DEPRECATED. Use COLLECTIONS_CONFIG instead.",
  "_comment_OLD_FORMAT3": "If both exist, COLLECTIONS_CONFIG takes precedence.",

  "_DEPRECATED_SCENE_TILER_PARAMS": {
    "sentinel-2-l2a": {
      "assets": ["red", "green", "blue"],
      "color_formula": "Gamma+RGB+3.2+Saturation+0.8+Sigmoidal+RGB+12+0.35"
    }
  },
  "_DEPRECATED_MOSAIC_TILER_PARAMS": {
    "sentinel-2-l2a": {
      "assets": ["visual"]
    }
  },
  "_DEPRECATED_SEARCH_MIN_ZOOM_LEVELS": {
    "sentinel-2-l2a": {
      "medium": 4,
      "high": 7
    }
  },
  "_DEPRECATED_POPUP_DISPLAY_FIELDS": {
    "sentinel-2-l2a": ["datetime", "platform", "eo:cloud_cover"]
  },
  "_DEPRECATED_TILE_LAYER_PARAMS": {
    "sentinel-2-l2a": {
      "minZoom": 2,
      "maxZoom": 26
    }
  },
  "_DEPRECATED_ENHANCED_DISPLAY_CONFIG": {
    "sentinel-2-l2a": {
      "property_groups": []
    }
  },

  "APP_NAME": "Filmdrop UI",
  "EXPORT_ENABLED": true
}
